rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: Get user data from Firestore
    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    // Multi-role support: checks primaryRole, role, and roles[] list
    function hasAnyRole(roleList) {
      let userData = getUserData();
      return userData.primaryRole in roleList
          || userData.role in roleList
          || (userData.roles != null && userData.roles.hasAny(roleList));
    }

    function isSuperAdmin() {
      return request.auth != null && hasAnyRole(['super_admin']);
    }

    function isHR() {
      return request.auth != null && hasAnyRole(['hr']);
    }

    function isManager() {
      return request.auth != null && hasAnyRole(['manager']);
    }

    match /attendance_selfies/{authUid}/{fileName} {
      // Employees can upload their own selfies.
      allow create: if request.auth != null && request.auth.uid == authUid
                    && request.resource.size < 5 * 1024 * 1024 // max 5MB
                    && request.resource.contentType.matches('image/.*');
      
      // Only the employee, HR, Manager, or Superadmin can read the selfie.
      allow read: if request.auth != null && (
        request.auth.uid == authUid || 
        isSuperAdmin() || 
        isHR() || 
        isManager()
      );
      
      // Deletion only by Superadmin
      allow delete: if isSuperAdmin();
      allow update: if false; // Selfies shouldn't be updated/replaced
    }
  }
}
