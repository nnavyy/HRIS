rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function hasRole(roleName) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return (userData.role == roleName) || 
             (userData.primaryRole == roleName) || 
             (userData.roles != null && roleName in userData.roles);
    }

    function isSuperAdmin() {
      return isLoggedIn() && hasRole('super_admin');
    }

    function isHR() {
      return isLoggedIn() && hasRole('hr');
    }

    function isFinance() {
      return isLoggedIn() && hasRole('finance');
    }

    function isManager() {
      return isLoggedIn() && hasRole('manager');
    }

    // --- USERS ---
    match /users/{userId} {
      allow read: if isLoggedIn();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || request.auth.uid == userId;
      allow delete: if isSuperAdmin();
    }

    // --- EMPLOYEES ---
    match /employees/{employeeId} {
      allow read: if isLoggedIn();
      allow create: if isSuperAdmin() || isHR();
      allow update: if isSuperAdmin() || isHR() || isManager() || isLoggedIn();
      allow delete: if isSuperAdmin() || isHR();
    }

    // --- OFFICE LOCATIONS ---
    match /office_locations/{officeId} {
      allow read: if isLoggedIn();
      allow write: if isSuperAdmin() || isHR();
    }

    // --- ATTENDANCE ---
    match /attendance/{attendanceId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isSuperAdmin() || isHR();
    }

    // --- PAYROLLS ---
    match /payrolls/{payrollId} {
      allow read: if isLoggedIn();
      allow create: if isSuperAdmin() || isFinance();
      allow update: if isSuperAdmin() || isFinance() || isManager();
      allow delete: if isSuperAdmin();
    }

    // --- LEAVE REQUESTS ---
    match /leave_requests/{leaveId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isSuperAdmin() || isHR() || isManager() || isLoggedIn();
      allow delete: if isSuperAdmin() || isHR();
    }

    // --- AUDIT LOGS ---
    match /audit_logs/{logId} {
      allow read: if isSuperAdmin() || isHR();
      allow create: if isLoggedIn();
      allow update, delete: if false;
    }

    // --- KPI ---
    match /kpi_configs/{configId} {
      allow read: if isLoggedIn();
      allow write: if isSuperAdmin() || isHR() || isManager();
    }

    match /kpi_scores/{scoreId} {
      allow read: if isLoggedIn();
      allow write: if isSuperAdmin() || isHR() || isManager();
    }

    // --- AUTOMATION RULES ---
    match /automation_rules/{ruleId} {
      allow read: if isLoggedIn();
      allow write: if isSuperAdmin();
    }

    // --- NOTIFICATIONS ---
    match /notifications/{notifId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    // --- SERVER TIME PROBE (Anti-Clock Manipulation) ---
    match /_server_time_check/{docId} {
      allow read, write: if isLoggedIn();
    }

    // --- OTHER COLLECTIONS ---
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}

